# /etc/systemd/system/finance-backup.timer
# 每周日 03:00 触发备份
#
# 启用:
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now finance-backup.timer
#   systemctl list-timers finance-backup
[Unit]
Description=Finance Weekly Backup Timer
Requires=finance-backup.service

[Timer]
OnCalendar=Sun 03:00:00
RandomizedDelaySec=15m
# 错过(机器关机)上次会补一次 — systemd 不支持值后的行内注释,注释必须独占一行
Persistent=true

[Install]
WantedBy=timers.target
