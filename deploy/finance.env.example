# /etc/finance.env — 生产环境变量(填好后 chmod 600)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=finance
DB_USER=finance
DB_PASS=please-change-me

# Spring 把 ${DB_*} 注入 application.yml 的 datasource
# 也可在这里覆盖 app.upload-root / app.remember-me-key 等
UPLOAD_ROOT=/var/finance/uploads
REMEMBER_ME_KEY=please-generate-a-random-32+-chars-here
