<?xml version="1.0" encoding="UTF-8"?>
<!--
  Maven 配置 · 国内 mirror 加速
  ============================================================
  deploy/deploy.sh 步 11 会自动 cp 这个到 ~/.m2/settings.xml(若没有 / 不含 aliyun)
  也可以手动用:cp deploy/maven-settings.xml ~/.m2/settings.xml

  mirrorOf 语义:
    "*"             → 拦截所有仓库,全走阿里云(最快)
    "*,!jitpack.io" → 阿里云 + 例外 jitpack.io(某些三方 lib 在 jitpack)
    "central"       → 只拦截 maven central(保守)

  默认用 *,!jitpack.io。我们 v0.2 没用 jitpack,但留个例外做未来兼容。

  其它候选 mirror(网络变化时可改):
    阿里云  https://maven.aliyun.com/repository/public
    华为云  https://mirrors.huaweicloud.com/repository/maven
    腾讯云  https://mirrors.cloud.tencent.com/nexus/repository/maven-public
    网易    https://mirrors.163.com/maven/repository/maven-public
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
                              http://maven.apache.org/xsd/settings-1.0.0.xsd">

  <mirrors>
    <mirror>
      <id>aliyun-public</id>
      <mirrorOf>*,!jitpack.io</mirrorOf>
      <name>Aliyun Maven Public</name>
      <url>https://maven.aliyun.com/repository/public</url>
    </mirror>
  </mirrors>

  <!-- 可选:仓库镜像之外,直连一些特别仓库时也走 https -->
  <profiles>
    <profile>
      <id>aliyun-defaults</id>
      <repositories>
        <repository>
          <id>aliyun-public</id>
          <url>https://maven.aliyun.com/repository/public</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>false</enabled></snapshots>
        </repository>
      </repositories>
      <pluginRepositories>
        <pluginRepository>
          <id>aliyun-public-plugins</id>
          <url>https://maven.aliyun.com/repository/public</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>false</enabled></snapshots>
        </pluginRepository>
      </pluginRepositories>
    </profile>
  </profiles>

  <activeProfiles>
    <activeProfile>aliyun-defaults</activeProfile>
  </activeProfiles>
</settings>
