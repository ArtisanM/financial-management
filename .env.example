# 家庭账房 · v0.7 Docker 配置 —— 复制为 .env(git-ignored)
# 懒人:跑 `bash deploy/docker-init.sh` 自动生成下面的随机密钥。

# ── 数据库 ──
DB_NAME=finance
DB_USER=finance
DB_PASS=请改成强密码
MYSQL_ROOT_PASSWORD=请改成另一个强密码

# ── 应用 ──
SERVER_PORT=20000
# 会话签名 key,改了会踢掉所有登录态;建议 32 字节随机:openssl rand -hex 32
REMEMBER_ME_KEY=请改成32字节随机串
TZ=Asia/Shanghai
# 种子账号(用户名 diwa / wangergou)首次登录的临时密码;首次登录后会强制改密。
# 留 demo1234 即可,想换就改这里(仅首装生效;已初始化的库不会被改)。
SEED_ADMIN_PASSWORD=demo1234
# 全新安装默认会清掉内置的演示数据,让你从「空态」开始(与 systemd 直装一致,会触发新手引导)。
# 想保留演示数据先看填充效果?设 FINANCE_KEEP_DEMO=1(仅对全新库生效,迁移/升级的库永不被动)。
# FINANCE_KEEP_DEMO=1

# ── 备份 sidecar ──
RETENTION_DAYS=56

# 说明:LLM key / 短信 aksk / checkup 阈值 等运营参数不在这里配 ——
# 首次登录后走管理页(/admin/integrations 等),存数据库,实时生效。
